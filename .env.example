# ─── Environment Variables ───────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_long
JWT_EXPIRES_IN=7d

# ── Neon DB ───────────────────────────────────────────────────────────────────
# Use the POOLER connection string from Neon dashboard (not the direct string)
# Pooler URL prevents connection exhaustion in high-concurrency NestJS server
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Folder where reels are stored in Cloudinary
CLOUDINARY_REELS_FOLDER=reels

# Signed upload preset (create in Cloudinary dashboard → Settings → Upload)
CLOUDINARY_UPLOAD_PRESET=reels_preset

# Webhook endpoint — must be publicly accessible (use ngrok for local dev)
# Example: https://your-domain.com/api/webhooks/cloudinary
CLOUDINARY_WEBHOOK_URL=https://your-api-domain.com/api/webhooks/cloudinary

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# From Upstash console: upstash.com → Create Database → Copy REST URL + token
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8081,exp://localhost:8081
