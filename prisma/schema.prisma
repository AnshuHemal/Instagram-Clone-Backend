// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — Instagram Clone Backend
// Database: Neon DB (serverless PostgreSQL)
// ORM:      Prisma 5
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ReelStatus {
  PROCESSING // Cloudinary is transcoding
  READY      // HLS URL is available, reel is live
  FAILED     // Transcoding failed
}

enum FollowRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Represents a user account.
model User {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username             String   @unique @db.VarChar(30)
  email                String   @unique
  phone                String?  @unique @db.VarChar(20)
  passwordHash         String?  @db.VarChar(255)
  birthday             DateTime?
  displayName          String   @db.VarChar(50)
  avatarUrl            String?
  bio                  String?  @db.VarChar(150)
  gender               String?  @db.VarChar(30)
  pronouns             String?  @db.VarChar(30)
  links                Json?    @default("[]")
  showPronounsToFollowers Boolean @default(false)
  isVerified           Boolean  @default(false)
  isPrivate            Boolean  @default(false)
  isOnboarded          Boolean  @default(false)
  onboardingStep       String   @default("PERMISSIONS") @db.VarChar(30)
  pushToken            String?  @db.VarChar(200)
  notificationPreferences Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  reels                Reel[]
  likes                ReelLike[]
  views                ReelView[]
  followers            Follow[]   @relation("following")
  following            Follow[]   @relation("follower")
  posts                Post[]
  postLikes            PostLike[]
  postComments         PostComment[]
  reelComments         ReelComment[]
  commentLikes         CommentLike[]
  savedPosts           SavedPost[]
  sentFollowRequests   FollowRequest[] @relation("FollowRequestSender")
  receivedFollowRequests FollowRequest[] @relation("FollowRequestReceiver")
  notifications        Notification[] @relation("notificationRecipient")
  actorNotifications   Notification[] @relation("notificationActor")
  chatParticipants     ConversationParticipant[]
  sentMessages         Message[]
  stories              Story[]
  viewedStories        StoryViewer[]
  highlights           Highlight[]
  blockedUsers         Block[]  @relation("BlockerUser")
  blockedByUsers       Block[]  @relation("BlockedUser")
  mutedUsers           Mute[]   @relation("MuterUser")
  mutedByUsers         Mute[]   @relation("MutedByUser")
  messageReactions     MessageReaction[]

  @@index([username])
}

/// A Reel video post.
model Reel {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String     @db.Uuid
  caption            String?    @db.VarChar(2200)
  audioName          String?    @db.VarChar(100)
  hashtags           String[]   @default([])

  cloudinaryPublicId String?    @unique
  hlsUrl             String?
  thumbnailUrl       String?
  durationSeconds    Float?

  viewsCount         BigInt     @default(0)
  likesCount         BigInt     @default(0)
  commentsCount      Int        @default(0)
  sharesCount        Int        @default(0)

  status             ReelStatus @default(PROCESSING)
  isDeleted          Boolean    @default(false)

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    ReelLike[]
  views    ReelView[]
  comments ReelComment[]

  @@index([status, createdAt(sort: Desc), id])
  @@index([userId, createdAt(sort: Desc)])
  @@index([cloudinaryPublicId])
}

model ReelLike {
  reelId    String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reelId, userId])
  @@index([reelId])
  @@index([userId])
}

model ReelView {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reelId          String   @db.Uuid
  userId          String   @db.Uuid
  watchDurationMs Int
  completed       Boolean  @default(false)
  quality         String?  @db.VarChar(10)
  createdAt       DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reelId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

/// Comments on a reel — supports nested replies.
model ReelComment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reelId     String   @db.Uuid
  userId     String   @db.Uuid
  text       String   @db.VarChar(2200)
  parentId   String?  @db.Uuid
  likesCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reel    Reel          @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  ReelComment?  @relation("ReelCommentReplies", fields: [parentId], references: [id])
  replies ReelComment[] @relation("ReelCommentReplies")
  likes   CommentLike[]

  @@index([reelId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([parentId])
}

/// Follow relationships between users.
model Follow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

/// Follow requests for private accounts.
model FollowRequest {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterId String              @db.Uuid
  targetId    String              @db.Uuid
  status      FollowRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  requester User @relation("FollowRequestSender", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User @relation("FollowRequestReceiver", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId, status])
  @@index([requesterId, status])
}

// ─── Hashtag Models ───────────────────────────────────────────────────────────

model Hashtag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tag       String   @unique @db.VarChar(100)
  postCount Int      @default(0)
  createdAt DateTime @default(now())

  posts     ContentHashtag[]

  @@index([tag])
}

/// Polymorphic join table linking hashtags to posts, reels, or comments.
model ContentHashtag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hashtagId   String   @db.Uuid
  contentId   String   @db.Uuid
  contentType String   @db.VarChar(20)
  createdAt   DateTime @default(now())

  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@index([hashtagId])
  @@index([contentId, contentType])
  @@index([contentType, createdAt(sort: Desc)])
}

// ─── Post Models ──────────────────────────────────────────────────────────────

model Post {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String        @db.Uuid
  caption       String?       @db.VarChar(2200)
  location      String?       @db.VarChar(100)
  likesCount    Int           @default(0)
  commentsCount Int           @default(0)
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  media         PostMedia[]
  likes         PostLike[]
  comments      PostComment[]
  savedBy       SavedPost[]

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model PostMedia {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId     String   @db.Uuid
  mediaUrl   String
  mediaType  String
  orderIndex Int      @default(0)

  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, orderIndex])
}

model PostLike {
  postId    String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([postId])
  @@index([userId])
}

/// Comments on a post — supports nested replies.
model PostComment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId     String   @db.Uuid
  userId     String   @db.Uuid
  text       String   @db.VarChar(2200)
  parentId   String?  @db.Uuid
  likesCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  PostComment?  @relation("PostCommentReplies", fields: [parentId], references: [id])
  replies PostComment[] @relation("PostCommentReplies")
  likes   CommentLike[]

  @@index([postId, createdAt(sort: Desc)])
  @@index([parentId])
}

/// Likes on individual comments (posts or reels).
model CommentLike {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid
  postCommentId String?  @db.Uuid
  reelCommentId String?  @db.Uuid
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  postComment PostComment? @relation(fields: [postCommentId], references: [id], onDelete: Cascade)
  reelComment ReelComment? @relation(fields: [reelCommentId], references: [id], onDelete: Cascade)

  @@unique([userId, postCommentId])
  @@unique([userId, reelCommentId])
  @@index([postCommentId])
  @@index([reelCommentId])
}

/// Saved/bookmarked posts by a user.
model SavedPost {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId  String   @db.Uuid
  postId  String   @db.Uuid
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, savedAt(sort: Desc)])
}

// ─── Notification Model ──────────────────────────────────────────────────────

enum NotificationType {
  FOLLOW
  FOLLOW_REQUEST
  FOLLOW_REQUEST_ACCEPTED
  LIKE_POST
  LIKE_REEL
  COMMENT_POST
  COMMENT_REEL
}

model Notification {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipientId String           @db.Uuid
  actorId     String           @db.Uuid
  type        NotificationType
  postId      String?          @db.Uuid
  reelId      String?          @db.Uuid
  commentText String?          @db.VarChar(200)
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipient User @relation("notificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User @relation("notificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([recipientId, read, createdAt(sort: Desc)])
  @@index([recipientId, createdAt(sort: Desc)])
}

// ─── Chat Models ─────────────────────────────────────────────────────────────

model Conversation {
  id           String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  isGroup      Boolean                   @default(false)
  groupName    String?                   @db.VarChar(100)
  groupAvatar  String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversationId String   @db.Uuid
  userId         String   @db.Uuid
  joinedAt       DateTime @default(now())
  isAdmin        Boolean  @default(false)

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @db.Uuid
  senderId       String   @db.Uuid
  text           String?  @db.VarChar(2200)
  mediaUrl       String?
  referenceType  String?  @db.VarChar(10)  // 'post' | 'reel' | 'story'
  referenceId    String?  @db.Uuid
  storyId        String?  @db.Uuid
  isRead         Boolean  @default(false)
  // NOTE: Run prisma migrate after adding replyToId field
  replyToId      String?  @db.Uuid
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  story          Story?       @relation(fields: [storyId], references: [id], onDelete: SetNull)
  reactions      MessageReaction[]

  @@index([conversationId, createdAt(sort: Desc)])
}

/// Emoji reactions on chat messages.
// NOTE: Run prisma migrate after adding MessageReaction model
model MessageReaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String   @db.VarChar(10)
  createdAt DateTime @default(now())

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
}

model Story {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  mediaUrl  String
  mediaType String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewers   StoryViewer[]
  highlights HighlightStory[]
  messages  Message[]

  @@index([expiresAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model StoryViewer {
  storyId  String   @db.Uuid
  viewerId String   @db.Uuid
  viewedAt DateTime @default(now())

  story  Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer User  @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@id([storyId, viewerId])
}

// ─── Highlights Models ────────────────────────────────────────────────────────

model Highlight {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @db.Uuid
  title     String           @db.VarChar(50)
  coverUrl  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories   HighlightStory[]

  @@index([userId, createdAt(sort: Desc)])
}

model HighlightStory {
  highlightId String    @db.Uuid
  storyId     String    @db.Uuid
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())

  highlight   Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  story       Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([highlightId, storyId])
  @@index([highlightId, orderIndex])
  @@index([storyId])
}

// NOTE: After adding these models, run `npx prisma migrate dev` in the backend directory to apply changes to the database.

/// Block relationship between users.
model Block {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blockerId   String   @db.Uuid
  blockedId   String   @db.Uuid
  createdAt   DateTime @default(now())

  blocker     User @relation("BlockerUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked     User @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

/// Mute relationship — user mutes another's posts/stories.
model Mute {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  muterId   String   @db.Uuid
  mutedId   String   @db.Uuid
  mutePosts  Boolean  @default(true)
  muteStories Boolean @default(false)
  createdAt DateTime @default(now())

  muter     User @relation("MuterUser", fields: [muterId], references: [id], onDelete: Cascade)
  muted     User @relation("MutedByUser", fields: [mutedId], references: [id], onDelete: Cascade)

  @@unique([muterId, mutedId])
  @@index([muterId])
}
